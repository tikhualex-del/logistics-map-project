// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id                  String                      @id @default(cuid())
  name                String
  timezone            String
  currency            String                      @default("RUB")
  distanceUnit        String                      @default("km")
  mapProvider         String                      @default("yandex")
  workingHoursJson    String?
  isActive            Boolean                     @default(true)
  createdAt           DateTime                    @default(now())

  memberships         Membership[]
  sessions            Session[]
  warehouses          Warehouse[]
  integrations        Integration[]
  integrationMappings IntegrationMapping[]
  orders              Order[]
  deliveryZones       DeliveryZone[]
  auditLogs           AuditLog[]

  loadUnits           CompanyLoadUnit[]
  courierCapacityRules CompanyCourierCapacityRule[]
  itemLoadMappings    IntegrationItemLoadMapping[]
  couriers            Courier[]
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  fullName     String
  passwordHash String
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())

  memberships  Membership[]
  sessions     Session[]
  auditLogs    AuditLog[]   @relation("AuditLogActor")
}

model Membership {
  id         String    @id @default(cuid())
  userId     String
  companyId  String
  role       String
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

model Session {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  companyId  String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([token])
}

model Warehouse {
  id         String    @id @default(cuid())
  companyId  String
  name       String
  city       String
  address    String
  latitude   Float?
  longitude  Float?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@index([companyId])
}

model Integration {
  id                       String                       @id @default(cuid())
  companyId                String
  name                     String
  provider                 String
  baseUrl                  String?
  credentialsEncryptedJson String
  isActive                 Boolean                      @default(true)
  isDefault                Boolean                      @default(false)
  createdAt                DateTime                     @default(now())

  company                  Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  mappings                 IntegrationMapping[]
  orders                   Order[]
  itemLoadMappings         IntegrationItemLoadMapping[]

  @@index([companyId])
}

model IntegrationMapping {
  id                  String       @id @default(cuid())
  companyId           String
  integrationId       String
  orderStatusMapJson  String
  deliveryTypeMapJson String
  warehouseMapJson    String?
  courierMapJson      String?
  mapStatusConfigJson String?
  createdAt           DateTime     @default(now())

  company             Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integration         Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([companyId, integrationId])
  @@index([companyId])
  @@index([integrationId])
}

model Order {
  id                 String            @id @default(cuid())
  companyId          String
  integrationId      String?
  warehouseId        String?

  externalId         String
  title              String

  status             String
  deliveryType       String

  address            String
  latitude           Float?
  longitude          Float?

  deliveryWindowFrom String?
  deliveryWindowTo   String?

  courierExternalId  String?
  courierName        String?

  rawPayloadJson     String?

  zoneId             String?

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  company            Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integration        Integration?      @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  warehouse          Warehouse?        @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  loadItems          OrderLoadItem[]
  loadSnapshot       OrderLoadSnapshot?
  capacityPoints     Int      @default(0)


  @@index([companyId])
  @@index([integrationId])
  @@index([warehouseId])
  @@index([externalId])
  @@unique([companyId, integrationId, externalId])
  @@index([zoneId])
}

model DeliveryZone {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  color         String   @default("#2563eb")
  polygonJson   String
  price         Decimal? @db.Decimal(10, 2)
  priority      Int      @default(100)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, isActive])
  @@index([companyId, priority])
}

model CompanyLoadUnit {
  id                  String                       @id @default(cuid())
  companyId           String
  name                String
  code                String
  description         String?
  capacityPoints      Int
  allowedCourierTypes String?
  isActive            Boolean                      @default(true)
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  company             Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orderLoadItems      OrderLoadItem[]
  itemMappings        IntegrationItemLoadMapping[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, isActive])
}

model CompanyCourierCapacityRule {
  id                String   @id @default(cuid())
  companyId         String
  courierType       String
  maxOrders         Int
  maxCapacityPoints Int
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, courierType])
  @@index([companyId])
  @@index([companyId, isActive])
}

model IntegrationItemLoadMapping {
  id                String           @id @default(cuid())
  companyId         String
  integrationId     String
  externalFieldType String
  matchType         String
  externalValue     String
  loadUnitId        String
  multiplier        Int              @default(1)
  priority          Int              @default(100)
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integration       Integration      @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  loadUnit          CompanyLoadUnit  @relation(fields: [loadUnitId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([integrationId])
  @@index([loadUnitId])
  @@index([companyId, integrationId, isActive])
  @@index([companyId, integrationId, externalFieldType, matchType])
}

model OrderLoadItem {
  id              String           @id @default(cuid())
  orderId         String
  loadUnitId      String
  quantity        Int
  sourceMatchType String
  sourceRawValue  String?
  createdAt       DateTime         @default(now())

  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  loadUnit        CompanyLoadUnit  @relation(fields: [loadUnitId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([loadUnitId])
}

model OrderLoadSnapshot {
  id                     String   @id @default(cuid())
  orderId                String   @unique
  totalCapacityPoints    Int      @default(0)
  walkAllowed            Boolean?
  bikeAllowed            Boolean?
  carAllowed             Boolean?
  recommendedCourierType String?
  classificationStatus   String
  summaryJson            String?
  updatedAt              DateTime @updatedAt

  order                  Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([classificationStatus])
}

model GeocodeCache {
  id          String   @id @default(cuid())
  addressKey  String   @unique
  lat         Float?
  lon         Float?
  displayName String?
  kind        String?
  precision   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([addressKey])
}

model AddressDictionary {
  id               String   @id @default(cuid())
  country          String?  @default("RU")
  region           String?
  city             String?
  streetNormalized String
  streetOriginal   String?
  house            String
  housing          String?
  building         String?
  lat              Float
  lon              Float
  source           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([city])
  @@index([streetNormalized])
  @@index([city, streetNormalized, house, housing, building])
}

model LoginRateLimit {
  id              String   @id @default(cuid())
  key             String   @unique
  ip              String
  email           String
  attempts        Int      @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ip])
  @@index([email])
  @@index([blockedUntil])
}

model CronExecutionLock {
  key         String   @id
  lockedUntil DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lockedUntil])
}

model AuditLog {
  id                 String   @id @default(cuid())
  companyId          String
  actorUserId        String
  targetUserId       String?
  targetMembershipId String?
  action             String
  metaJson           String?
  createdAt          DateTime @default(now())

  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actorUser          User     @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([targetMembershipId])
  @@index([action])
  @@index([createdAt])
}

model Courier {
  id                String   @id @default(cuid())
  companyId         String
  fullName          String
  phone             String?
  courierType       String   @default("walk")
  maxCapacityPoints Int?
  homeAddress       String?
  homeLat           Float?
  homeLon           Float?
  scheduleJson      String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, isActive])
}